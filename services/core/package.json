{
  "name": "@vestara/core",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "development": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./*": {
      "types": "./src/*",
      "development": "./src/*",
      "default": "./dist/*.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@vestara/constants": "workspace:*",
    "@vestara/types": "workspace:*",
    "@vestara/utils": "workspace:*",
    "@vestara/config": "workspace:*",
    "better-sqlite3": "^11.8.0",
    "pino": "^9.6.0",
    "pino-pretty": "^13.0.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0",
    "typescript": "^5.7.0"
  }
}
