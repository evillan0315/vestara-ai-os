{
  "name": "@vestara/api",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@fastify/cors": "^11.0.0",
    "@fastify/static": "^8.1.0",
    "@fastify/websocket": "^11.0.0",
    "@vestara/config": "workspace:*",
    "@vestara/constants": "workspace:*",
    "@vestara/core": "workspace:*",
    "@vestara/types": "workspace:*",
    "@vestara/utils": "workspace:*",
    "@vestara/validation": "workspace:*",
    "bcryptjs": "^2.4.3",
    "fastify": "^5.2.0",
    "jsonwebtoken": "^9.0.2"
  },
  "devDependencies": {
    "@fastify/rate-limit": "^11.1.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^4.1.10"
  }
}
