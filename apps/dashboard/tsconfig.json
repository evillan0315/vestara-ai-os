{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "./src",
    "jsx": "react-jsx",
    "paths": {
      "@vestara/types": ["../../packages/types/src"],
      "@vestara/types/*": ["../../packages/types/src/*"],
      "@vestara/validation": ["../../packages/validation/src"],
      "@vestara/validation/*": ["../../packages/validation/src/*"],
      "@vestara/constants": ["../../packages/constants/src"],
      "@vestara/constants/*": ["../../packages/constants/src/*"]
    }
  },
  "include": ["src/**/*.ts", "src/**/*.tsx"],
  "exclude": ["node_modules", "dist"]
}
