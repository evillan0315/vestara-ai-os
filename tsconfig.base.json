{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022", "DOM"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "composite": true,
    "outDir": "./dist",
    "baseUrl": ".",
    "paths": {
      "@vestara/types": ["./packages/types/src"],
      "@vestara/types/*": ["./packages/types/src/*"],
      "@vestara/constants": ["./packages/constants/src"],
      "@vestara/constants/*": ["./packages/constants/src/*"],
      "@vestara/validation": ["./packages/validation/src"],
      "@vestara/validation/*": ["./packages/validation/src/*"],
      "@vestara/utils": ["./packages/utils/src"],
      "@vestara/utils/*": ["./packages/utils/src/*"],
      "@vestara/config": ["./packages/config/src"],
      "@vestara/config/*": ["./packages/config/src/*"],
      "@vestara/core": ["./services/core/src"],
      "@vestara/core/*": ["./services/core/src/*"]
    }
  },
  "exclude": ["node_modules", "dist"]
}
