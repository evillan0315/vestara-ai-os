{
  "name": "vestara-ai-os",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Vestara AI OS — A portable AI operating system that boots from an external SSD",
  "scripts": {
    "dev": "turbo dev",
    "dev:api": "turbo dev --filter=@vestara/api",
    "dev:dashboard": "turbo dev --filter=@vestara/dashboard",
    "build": "turbo build",
    "build:packages": "turbo build --filter='./packages/*'",
    "build:core": "turbo build --filter=@vestara/core",
    "build:api": "turbo build --filter=@vestara/api",
    "build:dashboard": "turbo build --filter=@vestara/dashboard",
    "typecheck": "turbo typecheck",
    "lint": "turbo lint",
    "test": "turbo test",
    "clean": "turbo clean && rm -rf node_modules"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "@vitest/coverage-v8": "^4.1.10",
    "turbo": "^2.10.4",
    "typescript": "^5.7.0",
    "vitest": "^4.1.10"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild"
    ]
  },
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=10.0.0"
  },
  "packageManager": "pnpm@10.6.0"
}
